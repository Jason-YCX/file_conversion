{
  "name": "qingzhuan-file-converter",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/api"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "dev:api": "npm run start:dev --workspace @qingzhuan/api",
    "dev:worker": "npm run start:worker:dev --workspace @qingzhuan/api",
    "dev:full": "npm run infra:up && concurrently -k -n web,api,worker -c cyan,magenta,yellow \"npm:dev:web\" \"npm:dev:api\" \"npm:dev:worker\"",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "build": "npm run build:web && npm run build:api",
    "build:web": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "build:api": "npm run build --workspace @qingzhuan/api",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "start:web:prod": "node dist/standalone/server.js",
    "deploy:prod": "./scripts/deploy.sh",
    "backup:prod": "./scripts/backup.sh",
    "restore:prod": "./scripts/restore.sh",
    "rollback:prod": "./scripts/rollback.sh",
    "cleanup:prod": "./scripts/cleanup-images.sh",
    "nginx:install": "./scripts/install-nginx-site.sh",
    "certs:check": "./scripts/check-certificates.sh",
    "certs:reload": "./scripts/reload-certificates.sh",
    "test": "npm run test:web && npm run test:api",
    "test:web": "npm run build:web && node --test tests/rendered-html.test.mjs",
    "test:api": "npm run test --workspace @qingzhuan/api",
    "lint": "npm run lint:web && npm run lint:api",
    "lint:web": "eslint app lib tests worker --ignore-pattern dist --ignore-pattern .next",
    "lint:api": "npm run lint --workspace @qingzhuan/api"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "concurrently": "^9.2.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
