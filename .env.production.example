# Public domains. Point all three DNS records to this server before deployment.
APP_DOMAIN=qingzhuan.jason-ycx.top
API_DOMAIN=qingzhuan-api.jason-ycx.top
FILES_DOMAIN=qingzhuan-files.jason-ycx.top

# Tencent TCR images are built by GitHub Actions and pulled by the server.
TCR_REGISTRY=ccr.ccs.tencentyun.com
TCR_NAMESPACE=jason-docker
WEB_IMAGE=file-conversion-web
BACKEND_IMAGE=file-conversion-backend

# Use URL-safe hexadecimal secrets, for example: openssl rand -hex 24
POSTGRES_DB=qingzhuan
POSTGRES_USER=qingzhuan
POSTGRES_PASSWORD=replace-with-a-random-hex-secret
REDIS_PASSWORD=replace-with-a-different-random-hex-secret
MINIO_ROOT_USER=qingzhuan-prod
MINIO_ROOT_PASSWORD=replace-with-another-random-hex-secret
S3_BUCKET=qingzhuan-files

# Conversion limits and retention policy.
MAX_UPLOAD_BYTES=52428800
MAX_INPUT_PIXELS=40000000
UPLOAD_URL_EXPIRES_SECONDS=900
DOWNLOAD_URL_EXPIRES_SECONDS=900
CONVERSION_WORKER_CONCURRENCY=1
ARCHIVE_WORKER_CONCURRENCY=1
CONVERSION_TIMEOUT_MS=180000
FILE_RETENTION_SECONDS=7200
FILE_CLEANUP_INTERVAL_SECONDS=600
