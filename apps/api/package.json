{
  "name": "@qingzhuan/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "lint": "tsc -p tsconfig.json --noEmit",
